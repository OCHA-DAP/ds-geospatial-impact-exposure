# Team Azure Blob account prefix (account = {prefix}{stage}); same as the viewer repo.
GIEX_BLOB_ACCOUNT_PREFIX=
GIEX_STAGE=dev
GIEX_CONTAINER=projects
GIEX_PROJECT_PREFIX=ds-geospatial-impact-exposure
# SAS tokens are NOT set here — they are read from the shared shell environment
# (the same DSCI_AZ_BLOB_{DEV,PROD}_SAS[_WRITE] tokens ocha-stratus uses).
